<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\ZibStack.NET.Dto\ZibStack.NET.Dto.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\..\ZibStack.NET.Core\src\ZibStack.NET.Core\ZibStack.NET.Core.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\..\ZibStack.NET.EntityFramework\src\ZibStack.NET.EntityFramework\ZibStack.NET.EntityFramework.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\..\ZibStack.NET.UI\src\ZibStack.NET.UI\ZibStack.NET.UI.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\..\ZibStack.NET.Validation\src\ZibStack.NET.Validation\ZibStack.NET.Validation.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\..\ZibStack.NET.Query\src\ZibStack.NET.Query\ZibStack.NET.Query.csproj" />
    <!-- TypeGen sees [CrudApi] already present on the Dto models and contributes
         the matching `paths:` block to the generated openapi.yaml — this is the
         canonical Dto + TypeGen integration demo. -->
    <ProjectReference Include="..\..\..\ZibStack.NET.TypeGen\src\ZibStack.NET.TypeGen\ZibStack.NET.TypeGen.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\..\ZibStack.NET.TypeGen\src\ZibStack.NET.TypeGen.Abstractions\ZibStack.NET.TypeGen.Abstractions.csproj" />
  </ItemGroup>

  <!-- Pick up the TypeGen .props (CompilerVisibleProperty for live-regen on save)
       AND the post-build .ts/.yaml writer target. NuGet consumers get both auto
       via build/<pkg>.props + build/<pkg>.targets; in-repo ProjectReference users
       wire both manually. -->
  <Import Project="..\..\..\ZibStack.NET.TypeGen\src\ZibStack.NET.TypeGen\build\ZibStack.NET.TypeGen.props" />
  <Import Project="..\..\..\ZibStack.NET.TypeGen\src\ZibStack.NET.TypeGen\build\ZibStack.NET.TypeGen.targets" />

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.5" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.5" />
    <PackageReference Include="Scalar.AspNetCore" Version="2.13.20" />
  </ItemGroup>

</Project>
