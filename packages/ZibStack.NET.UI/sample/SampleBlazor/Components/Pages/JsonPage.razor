@page "/json"
@using SampleBlazor.Models
@using System.Text.Json

<h2>Generated JSON Schemas</h2>

<h3>Form Schema</h3>
<pre>@_formJson</pre>

<h3>Table Schema</h3>
<pre>@_tableJson</pre>

@code {
    private string _formJson = "";
    private string _tableJson = "";

    protected override void OnInitialized()
    {
        // Pretty-print the compile-time baked JSON
        var formDoc = JsonDocument.Parse(Player.GetFormSchemaJson());
        _formJson = JsonSerializer.Serialize(formDoc, new JsonSerializerOptions { WriteIndented = true });

        var tableDoc = JsonDocument.Parse(Player.GetTableSchemaJson());
        _tableJson = JsonSerializer.Serialize(tableDoc, new JsonSerializerOptions { WriteIndented = true });
    }
}
