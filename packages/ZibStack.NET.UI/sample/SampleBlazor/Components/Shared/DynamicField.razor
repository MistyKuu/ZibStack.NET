@using SampleBlazor.Models

@if (IsVisible)
{
    <div class="form-group @(HasError ? "has-error" : "")">
        <label for="@Field.Name">
            @(Field.Label ?? Field.Name)
            @if (Field.Required == true)
            {
                <span class="required">*</span>
            }
        </label>

        @switch (Field.UiHint)
        {
            case "text":
                <input id="@Field.Name" type="text"
                       placeholder="@Field.Placeholder"
                       disabled="@(Field.Disabled == true)"
                       readonly="@(Field.ReadOnly == true)"
                       required="@(Field.Required == true)"
                       minlength="@GetValidation("minLength")"
                       maxlength="@GetValidation("maxLength")"
                       pattern="@GetValidation("pattern")"
                       value="@GetStringValue()"
                       @oninput="OnTextInput" />
                break;

            case "password":
                <input id="@Field.Name" type="password"
                       placeholder="@Field.Placeholder"
                       required="@(Field.Required == true)"
                       minlength="@GetValidation("minLength")"
                       maxlength="@GetValidation("maxLength")"
                       value="@GetStringValue()"
                       @oninput="OnTextInput" />
                break;

            case "number":
                <input id="@Field.Name" type="number"
                       required="@(Field.Required == true)"
                       min="@GetValidation("min")"
                       max="@GetValidation("max")"
                       value="@GetStringValue()"
                       @oninput="OnTextInput" />
                break;

            case "textarea":
                <textarea id="@Field.Name"
                          rows="@GetProp("rows", "3")"
                          placeholder="@Field.Placeholder"
                          required="@(Field.Required == true)"
                          minlength="@GetValidation("minLength")"
                          maxlength="@GetValidation("maxLength")"
                          @oninput="OnTextInput">@GetStringValue()</textarea>
                break;

            case "checkbox":
                <input id="@Field.Name" type="checkbox"
                       checked="@GetBoolValue()"
                       @onchange="OnCheckboxChange" />
                break;

            case "select":
                <select id="@Field.Name" required="@(Field.Required == true)" @onchange="OnSelectChange">
                    <option value="">-- Select --</option>
                    @if (Field.Options is not null)
                    {
                        @foreach (var opt in Field.Options)
                        {
                            <option value="@opt.Value" selected="@(GetStringValue() == opt.Value)">@opt.Label</option>
                        }
                    }
                </select>
                break;

            case "radioGroup":
                <div class="radio-group">
                    @if (Field.Options is not null)
                    {
                        @foreach (var opt in Field.Options)
                        {
                            <label>
                                <input type="radio" name="@Field.Name"
                                       value="@opt.Value"
                                       checked="@(GetStringValue() == opt.Value)"
                                       @onchange="@(() => SetValue(opt.Value))" />
                                @opt.Label
                            </label>
                        }
                    }
                </div>
                break;

            case "slider":
                <div class="slider-wrapper">
                    <input id="@Field.Name" type="range"
                           min="@GetProp("min", "0")"
                           max="@GetProp("max", "100")"
                           step="@GetProp("step", "1")"
                           value="@GetStringValue()"
                           @oninput="OnTextInput" />
                    <span>@(GetStringValue() ?? "0")</span>
                </div>
                break;

            case "datePicker":
                <input id="@Field.Name" type="date"
                       required="@(Field.Required == true)"
                       value="@GetStringValue()"
                       @oninput="OnTextInput" />
                break;

            case "dateTimePicker":
                <input id="@Field.Name" type="datetime-local"
                       required="@(Field.Required == true)"
                       value="@GetStringValue()"
                       @oninput="OnTextInput" />
                break;

            case "timePicker":
                <input id="@Field.Name" type="time"
                       required="@(Field.Required == true)"
                       value="@GetStringValue()"
                       @oninput="OnTextInput" />
                break;

            case "filePicker":
                <input id="@Field.Name" type="file"
                       required="@(Field.Required == true)"
                       accept="@GetProp("accept", "*/*")"
                       multiple="@(GetProp("multiple", "false") == "true")" />
                break;

            case "colorPicker":
                <input id="@Field.Name" type="color"
                       value="@(GetStringValue() ?? "#000000")"
                       @oninput="OnTextInput" />
                break;

            case "richText":
                <textarea id="@Field.Name" rows="6"
                          required="@(Field.Required == true)"
                          @oninput="OnTextInput">@GetStringValue()</textarea>
                break;

            default:
                <input id="@Field.Name" type="text"
                       required="@(Field.Required == true)"
                       value="@GetStringValue()"
                       @oninput="OnTextInput" />
                break;
        }

        @if (HasError)
        {
            <span class="validation-error">@ErrorMessage</span>
        }

        @if (Field.HelpText is not null)
        {
            <small class="help-text">@Field.HelpText</small>
        }
    </div>
}

@code {
    [Parameter, EditorRequired]
    public FieldSchema Field { get; set; } = default!;

    [Parameter, EditorRequired]
    public Dictionary<string, object?> Values { get; set; } = default!;

    [Parameter]
    public EventCallback OnValueChanged { get; set; }

    [Parameter]
    public Dictionary<string, string>? Errors { get; set; }

    private bool HasError => Errors?.ContainsKey(Field.Name) == true;
    private string? ErrorMessage => Errors?.GetValueOrDefault(Field.Name);

    private bool IsVisible
    {
        get
        {
            if (Field.Hidden == true) return false;
            if (Field.Conditional is null) return true;

            Values.TryGetValue(Field.Conditional.Field, out var depVal);
            var actual = depVal?.ToString() ?? "";
            var expected = Field.Conditional.Value;

            return Field.Conditional.Operator switch
            {
                "equals" => string.Equals(actual, expected, StringComparison.OrdinalIgnoreCase),
                "notEquals" => !string.Equals(actual, expected, StringComparison.OrdinalIgnoreCase),
                "contains" => actual.Contains(expected, StringComparison.OrdinalIgnoreCase),
                _ => true
            };
        }
    }

    private string? GetStringValue()
    {
        Values.TryGetValue(Field.Name, out var val);
        return val?.ToString();
    }

    private bool GetBoolValue()
    {
        Values.TryGetValue(Field.Name, out var val);
        return val is true or "true" or "True";
    }

    private string GetProp(string key, string fallback)
    {
        if (Field.Props?.TryGetValue(key, out var v) == true)
            return v?.ToString() ?? fallback;
        return fallback;
    }

    private string? GetValidation(string key)
    {
        if (Field.Validation?.TryGetValue(key, out var v) == true)
            return v?.ToString();
        return null;
    }

    private async Task SetValue(object? value)
    {
        Values[Field.Name] = value;
        if (OnValueChanged.HasDelegate)
            await OnValueChanged.InvokeAsync();
    }

    private Task OnTextInput(ChangeEventArgs e) => SetValue(e.Value);
    private Task OnSelectChange(ChangeEventArgs e) => SetValue(e.Value);
    private Task OnCheckboxChange(ChangeEventArgs e) => SetValue(e.Value is true or "true" or "True");
}
