<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <!-- Tests exercise the generator's internal types directly (emitters, schema
         model) via InternalsVisibleTo-style access granted below. -->
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <!-- Real OpenAPI parser — integration tests round-trip the emitter's YAML/JSON
         through this so we catch anything that merely LOOKS like valid output but
         isn't a legal OpenAPI document. -->
    <PackageReference Include="Microsoft.OpenApi.Readers" Version="1.6.22" />
    <!-- Needed so native-controller-scan tests can compile fragments containing
         [ApiController] / [HttpX] / ControllerBase. Without the framework ref
         the in-test Compilation sees those as unresolved and the scan returns
         empty, silently passing the tests. -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <!-- We reference the generator project normally (not as Analyzer) so the tests
         can instantiate emitter types directly. The internal mirror enums/settings
         are exposed via InternalsVisibleTo below. -->
    <ProjectReference Include="..\..\src\ZibStack.NET.TypeGen\ZibStack.NET.TypeGen.csproj" />
    <ProjectReference Include="..\..\src\ZibStack.NET.TypeGen.Abstractions\ZibStack.NET.TypeGen.Abstractions.csproj" />
  </ItemGroup>

</Project>
