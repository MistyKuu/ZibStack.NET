<Project>

  <!--
    Reads the manifest .g.cs the source generator emits to obj/generated/ and
    writes the actual .ts / .yaml files to the user-configured OutputDir.

    The split is necessary because Roslyn source generators can only emit .cs
    files into the compilation — they cannot write to arbitrary disk paths
    during code generation. So we serialize each emitted file as string
    constants in a single .g.cs manifest, then this target parses the manifest
    and writes the real files post-build.

    Uses RoslynCodeTaskFactory so the task is inline C# inside the .targets file
    — no companion task DLL to ship, no extra package, no separate build of
    Microsoft.Build.Utilities.Core.
  -->

  <UsingTask TaskName="ZibStackTypeGenWriteOutput"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <ManifestPath ParameterType="System.String" Required="true" />
      <ProjectDir ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Text.RegularExpressions" />
      <Code Type="Fragment" Language="cs">
<![CDATA[
if (!File.Exists(ManifestPath))
{
    Log.LogMessage(MessageImportance.Low, "ZibStack.TypeGen: manifest not found at " + ManifestPath + " (no [GenerateTypes] classes?), skipping.");
    return true;
}

var content = File.ReadAllText(ManifestPath);

// FileCount = N
var countMatch = Regex.Match(content, @"FileCount\s*=\s*(\d+)");
if (!countMatch.Success)
{
    Log.LogWarning("ZibStack.TypeGen: could not read FileCount from manifest. Skipping.");
    return true;
}
int fileCount = int.Parse(countMatch.Groups[1].Value);

// Each file: TargetN, OutputDirN, FileNameN, ContentN — verbatim @"..." strings.
// Verbatim strings escape inner quotes by doubling: "" → ", which we reverse below.
var verbatim = new Regex(@"@""((?:[^""]|"""")*)""", RegexOptions.Singleline);
var fields = new System.Collections.Generic.Dictionary<string, string>();

// Match field declarations at the start of a line (after whitespace) to avoid
// false matches inside Content fields that happen to contain similar text.
string ReadField(string name)
{
    var m = Regex.Match(content, @"^\s+internal\s+const\s+string\s+" + name + @"\s*=\s*(@""(?:[^""]|"""")*"")", RegexOptions.Singleline | RegexOptions.Multiline);
    if (!m.Success) return null;
    var inner = verbatim.Match(m.Groups[1].Value).Groups[1].Value;
    return inner.Replace("\"\"", "\"");
}

int written = 0;
// Track every file we just wrote (full path, lowercased on Windows) and every
// directory we touched. After writing, we sweep each touched directory and
// delete any file that carries our @generated banner but isn't in this run's
// set — that's how renames / removed types stop leaking stale output.
var writtenPaths = new System.Collections.Generic.HashSet<string>(StringComparer.OrdinalIgnoreCase);
var touchedDirs = new System.Collections.Generic.HashSet<string>(StringComparer.OrdinalIgnoreCase);

for (int i = 0; i < fileCount; i++)
{
    var outputDir = ReadField("OutputDir" + i);
    var fileName = ReadField("FileName" + i);
    var fileContent = ReadField("Content" + i);
    var target = ReadField("Target" + i);
    if (outputDir == null || fileName == null || fileContent == null) continue;

    // Resolve relative to project dir if not absolute.
    string fullDir = Path.IsPathRooted(outputDir) ? outputDir : Path.Combine(ProjectDir, outputDir);
    Directory.CreateDirectory(fullDir);
    string fullPath = Path.Combine(fullDir, fileName);

    writtenPaths.Add(Path.GetFullPath(fullPath));
    touchedDirs.Add(Path.GetFullPath(fullDir));

    // Skip the write if file is unchanged — keeps mtime stable, helps incremental
    // build / file-watcher noise downstream (frontend dev servers, etc.).
    if (File.Exists(fullPath) && File.ReadAllText(fullPath) == fileContent)
    {
        Log.LogMessage(MessageImportance.Low, "ZibStack.TypeGen: " + fullPath + " (" + target + ") unchanged.");
        continue;
    }

    File.WriteAllText(fullPath, fileContent);
    Log.LogMessage(MessageImportance.High, "ZibStack.TypeGen: wrote " + fullPath + " (" + target + ", " + fileContent.Length + " chars)");
    written++;
}

// Sweep sibling directories of each touchedDir — catches stale output from
// previous OutputDir values (e.g. renamed from "generated/ts" to "generated/client").
var siblingDirs = new System.Collections.Generic.HashSet<string>(StringComparer.OrdinalIgnoreCase);
foreach (var td in touchedDirs)
{
    try
    {
        var parent = Directory.GetParent(td);
        if (parent == null) continue;
        if (string.Equals(Path.GetFullPath(parent.FullName), Path.GetFullPath(ProjectDir), StringComparison.OrdinalIgnoreCase)) continue;
        foreach (var sibling in Directory.EnumerateDirectories(parent.FullName))
        {
            var fullSibling = Path.GetFullPath(sibling);
            if (touchedDirs.Contains(fullSibling)) continue;
            foreach (var candidate in Directory.EnumerateFiles(sibling))
            {
                try
                {
                    using var fs = new FileStream(candidate, FileMode.Open, FileAccess.Read, FileShare.Read);
                    var buf = new byte[200];
                    int n = fs.Read(buf, 0, buf.Length);
                    var head = System.Text.Encoding.UTF8.GetString(buf, 0, n);
                    if (head.IndexOf("@generated by ZibStack.NET.TypeGen", StringComparison.Ordinal) >= 0)
                    {
                        touchedDirs.Add(fullSibling);
                        break;
                    }
                }
                catch { }
            }
        }
    }
    catch { }
}

// Sweep stale output. Match by banner — only files we generated previously get
// removed, so the user's hand-written files in the same directory are safe.
// Banner pattern matches every emitter (TypeScript / OpenAPI YAML / OpenAPI JSON /
// Python — all lead with "@generated by ZibStack.NET.TypeGen").
int removed = 0;
foreach (var dir in touchedDirs)
{
    if (!Directory.Exists(dir)) continue;
    foreach (var existing in Directory.EnumerateFiles(dir))
    {
        var fullExisting = Path.GetFullPath(existing);
        if (writtenPaths.Contains(fullExisting)) continue;
        // Cheap check first — only read the first 200 bytes to look for the banner.
        try
        {
            using var fs = new FileStream(fullExisting, FileMode.Open, FileAccess.Read, FileShare.Read);
            var buf = new byte[200];
            int n = fs.Read(buf, 0, buf.Length);
            var head = System.Text.Encoding.UTF8.GetString(buf, 0, n);
            if (head.IndexOf("@generated by ZibStack.NET.TypeGen", StringComparison.Ordinal) < 0) continue;
        }
        catch { continue; }   // file locked / unreadable — skip silently.

        try
        {
            File.Delete(fullExisting);
            Log.LogMessage(MessageImportance.High, "ZibStack.TypeGen: removed stale " + fullExisting);
            removed++;
        }
        catch (Exception ex)
        {
            Log.LogMessage(MessageImportance.Normal, "ZibStack.TypeGen: could not remove " + fullExisting + " — " + ex.Message);
        }
    }
}

if (written > 0 || removed > 0)
    Log.LogMessage(MessageImportance.High, "ZibStack.TypeGen: " + written + " file(s) written, " + removed + " stale removed.");
]]>
      </Code>
    </Task>
  </UsingTask>

  <!--
    Run after CoreCompile: at that point the generator has produced its manifest
    in obj/generated/. Bind to BuildDependsOn to ensure it runs in normal `dotnet
    build` and `dotnet pack` flows. The manifest is named deterministically by
    the source generator (ZibStack.TypeGen.Manifest.g.cs).
  -->
  <Target Name="ZibStackTypeGenWriteOutputFiles"
          AfterTargets="CoreCompile"
          Condition="Exists('$(IntermediateOutputPath)generated\ZibStack.NET.TypeGen\ZibStack.NET.TypeGen.Generator.TypeGenGenerator\ZibStack.TypeGen.Manifest.g.cs')">
    <PropertyGroup>
      <_ZibStackTypeGenManifest>$(IntermediateOutputPath)generated\ZibStack.NET.TypeGen\ZibStack.NET.TypeGen.Generator.TypeGenGenerator\ZibStack.TypeGen.Manifest.g.cs</_ZibStackTypeGenManifest>
    </PropertyGroup>
    <ZibStackTypeGenWriteOutput
        ManifestPath="$(_ZibStackTypeGenManifest)"
        ProjectDir="$(MSBuildProjectDirectory)" />
  </Target>

</Project>
