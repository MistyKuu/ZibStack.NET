<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <NoWarn>RS2008;RS1032;NU5128</NoWarn>
    <IsRoslynComponent>true</IsRoslynComponent>

    <PackageId>ZibStack.NET.TypeGen</PackageId>
    <Description>Roslyn source generator that emits TypeScript and OpenAPI 3.1 from C# DTOs annotated with [GenerateTypes]. Compile-time, zero reflection, no running app required. Per-class / per-property overrides via attributes; project-wide config via ITypeGenConfigurator.</Description>
    <Authors>$(Authors)</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/MistyKuu/ZibStack.NET</PackageProjectUrl>
    <RepositoryUrl>https://github.com/MistyKuu/ZibStack.NET</RepositoryUrl>
    <PackageTags>typegen;openapi;typescript;source-generator;codegen;roslyn</PackageTags>

    <IncludeBuildOutput>false</IncludeBuildOutput>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.3.4" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" PrivateAssets="all" />
  </ItemGroup>

  <!-- Shared DTO filtering semantics — same file linked into ZibStack.NET.Dto.
       See file header in shared/DtoSemantics.cs for the SSOT rationale. -->
  <ItemGroup>
    <Compile Include="$(MSBuildProjectDirectory)\..\..\..\..\shared\DtoSemantics.cs" Link="Shared\DtoSemantics.cs" />
  </ItemGroup>

  <ItemGroup>
    <!-- Abstractions is a real transitive dependency: consumers of the analyzer package
         need the runtime types ([GenerateTypes], [TsName], [OpenApiProperty],
         ITypeGenConfigurator, etc.). The generator itself doesn't reference these — it
         re-mirrors the schema in Model/SchemaModel.cs to keep the analyzer DLL free of
         runtime dependencies — but the consumer project absolutely needs them on the
         compile path. Without this ProjectReference NuGet would not pull Abstractions
         in automatically, and `[GenerateTypes]` / `ITypeGenConfigurator` would fail to
         resolve at the call site. Mirrors the same pattern used by ZibStack.NET.Aop
         and ZibStack.NET.Log. -->
    <ProjectReference Include="..\ZibStack.NET.TypeGen.Abstractions\ZibStack.NET.TypeGen.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <None Include="build\ZibStack.NET.TypeGen.props" Pack="true" PackagePath="build\" Condition="Exists('build\ZibStack.NET.TypeGen.props')" />
    <None Include="build\ZibStack.NET.TypeGen.targets" Pack="true" PackagePath="build\" Condition="Exists('build\ZibStack.NET.TypeGen.targets')" />
  </ItemGroup>

</Project>
