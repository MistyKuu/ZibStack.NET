<Project>
  <!-- Auto-enable C# interceptors for the namespaces emitted by ZibStack.NET.Log generators.
       Without these properties, the compiler errors with CS9137 ('interceptors' feature is
       not enabled in this namespace) when consuming generated interceptor code. -->
  <PropertyGroup>
    <!-- .NET 9+ stable name -->
    <InterceptorsNamespaces>$(InterceptorsNamespaces);ZibStack.Generated;ZibStack.Generated.Log</InterceptorsNamespaces>
    <!-- .NET 8 preview name (kept for back-compat) -->
    <InterceptorsPreviewNamespaces>$(InterceptorsPreviewNamespaces);ZibStack.Generated;ZibStack.Generated.Log</InterceptorsPreviewNamespaces>
  </PropertyGroup>
</Project>
