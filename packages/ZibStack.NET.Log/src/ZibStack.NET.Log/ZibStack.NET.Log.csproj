<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <NoWarn>RS2008;RSEXPERIMENTAL002;NU5128</NoWarn>
    <IsRoslynComponent>true</IsRoslynComponent>

    <!-- NuGet metadata -->
    <PackageId>ZibStack.NET.Log</PackageId>
    <Description>Lightweight compile-time logging via C# interceptors. Add [Log] to any method and ZibStack.NET.Log generates zero-allocation logging wrappers using LoggerMessage.Define.</Description>
    <Authors>$(Authors)</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/MistyKuu/ZibStack.NET</PackageProjectUrl>
    <RepositoryUrl>https://github.com/MistyKuu/ZibStack.NET</RepositoryUrl>
    <PackageTags>source-generator;logging;interceptors;aop;csharp;codegen</PackageTags>
    <PackageReadmeFile Condition="Exists('$(MSBuildProjectDirectory)\..\..\README.md')">README.md</PackageReadmeFile>

    <IncludeBuildOutput>false</IncludeBuildOutput>
    <!-- Intentionally NOT setting DevelopmentDependency=true.
         That flag tells NuGet to treat this as a dev-only package, which
         excludes compile assets and PREVENTS our Abstractions ProjectReference
         from being propagated as a transitive dependency to consumers. -->
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.3.4" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <!-- Abstractions is a real transitive dependency: consumers of the analyzer
         package need the runtime types (LogAttribute, LoggerStructuredExtensions,
         handler structs). Without this NuGet would not pull it in automatically. -->
    <ProjectReference Include="..\ZibStack.NET.Log.Abstractions\ZibStack.NET.Log.Abstractions.csproj" />

    <!-- Build the analyzer alongside this generator so its DLL exists at pack time.
         Bundled into the same NuGet package below; not referenced as an assembly. -->
    <ProjectReference Include="..\ZibStack.NET.Log.Analyzers\ZibStack.NET.Log.Analyzers.csproj"
                      ReferenceOutputAssembly="false"
                      OutputItemType="Analyzer"
                      PrivateAssets="all" />
  </ItemGroup>

  <!-- [Log] aspect is now handled by ZibStack.NET.Aop generator.
       This package only provides the interpolated-string logging interceptor.
       Exclude emitter files (they're linked into the AOP generator project). -->
  <ItemGroup>
    <Compile Remove="Generator\LogAspectEmitter.cs" />
    <Compile Remove="Generator\DiagnosticDescriptors.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <!-- Bundle the analyzer DLL so installing ZibStack.NET.Log automatically
         enables the ZLOG002 diagnostic. No separate package install required. -->
    <None Include="..\ZibStack.NET.Log.Analyzers\bin\$(Configuration)\netstandard2.0\ZibStack.NET.Log.Analyzers.dll"
          Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <!-- Auto-enable interceptor namespaces in consumer projects on restore. -->
    <None Include="build\ZibStack.NET.Log.props" Pack="true" PackagePath="build\" />
    <None Include="buildTransitive\ZibStack.NET.Log.props" Pack="true" PackagePath="buildTransitive\" />
    <!-- Shipped alongside the props — activated only when <ZibLogStrict>true</ZibLogStrict>
         is set in the consumer .csproj, to raise ZLOG002 from Info to Warning. -->
    <None Include="build\ZibLogStrict.editorconfig" Pack="true" PackagePath="build\" />
    <None Include="buildTransitive\ZibLogStrict.editorconfig" Pack="true" PackagePath="buildTransitive\" />
    <None Include="$(MSBuildProjectDirectory)\..\..\README.md" Pack="true" PackagePath="\" Condition="Exists('$(MSBuildProjectDirectory)\..\..\README.md')" />
  </ItemGroup>

</Project>
